{
  "name": "alpha-radar-openclaw-skill",
  "version": "1.0.1-optimized",
  "description": "Optimized Alpha Radar renderer and sample utilities",
  "main": "src/render.js",
  "license": "MIT",
  "type": "commonjs",
  "bin": {
    "alpha-radar-render": "./scripts/render-report.js",
    "alpha-radar-fetch-binance-public": "./scripts/fetch-binance-public.js"
  },
  "scripts": {
    "test": "node --test",
    "smoke": "node scripts/smoke.js",
    "report": "node scripts/render-report.js --input examples/sample-data.json --style report --output examples/sample-report.md",
    "square": "node scripts/render-report.js --input examples/sample-data.json --style square --output examples/sample-square.txt",
    "tg": "node scripts/render-report.js --input examples/sample-data.json --style tg --output examples/sample-tg.txt",
    "validate": "node scripts/render-report.js --input examples/sample-data.json --validate-only"
  },
  "dependencies": {
    "zod": "^4.3.6"
  }
}
